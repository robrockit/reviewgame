# E2E Test Environment Configuration
# Copy this file to .env.test and fill in real values.
# .env.test is gitignored — never commit credentials.
#
# These variables are also required as GitHub Actions secrets for CI.
# See: .github/workflows/e2e-tests.yml

# Base URL of the app under test (staging deployment or localhost)
E2E_BASE_URL=https://staging.reviewgame.app

# Premium teacher account (active paid subscription in staging Supabase)
# Used for: game creation, FJ, game flow, and all paid-feature tests
E2E_TEACHER_EMAIL=e2e-teacher-premium@yourdomain.com
E2E_TEACHER_PASSWORD=your-premium-teacher-password-here

# Free-tier teacher account (no subscription in staging Supabase)
# Used for: feature gating tests (FJ hidden, upgrade prompts shown)
E2E_FREE_TEACHER_EMAIL=e2e-teacher-free@yourdomain.com
E2E_FREE_TEACHER_PASSWORD=your-free-teacher-password-here

# Supabase staging project (kvygljdyzdhltngqvrii)
# Students join games anonymously via device_id — no student accounts needed
NEXT_PUBLIC_SUPABASE_URL=https://kvygljdyzdhltngqvrii.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key-here
